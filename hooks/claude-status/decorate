#!/usr/bin/env bash
# haunt hook: Claude Code status indicators
# Detects working/idle state from Ghostty tab title prefixes and tracks transitions.
#
# Input (stdin):  tabId \t tabName \t termName \t focused  (one per line)
# Output (stdout): tabId \t indicator  (only for tabs that need one)
#
# Detection: ✳ prefix (U+2733) = idle, braille spinner ⠂/⠐ (U+2800–U+28FF) = working
# Checks termName first (always updated by Claude), falls back to tabName.
#
# ◌ (dim) = Claude is working
# ✳ (yellow, full line) = Claude finished, needs input — cleared when tab is viewed

set -euo pipefail

STATEFILE="${TMPDIR:-/tmp}haunt-claude-states"
ATTENTIONFILE="${TMPDIR:-/tmp}haunt-claude-attention"

touch "$STATEFILE" "$ATTENTIONFILE"

LC_ALL=C awk -F'\t' '
BEGIN {
    statefile = "'"$STATEFILE"'"
    attentionfile = "'"$ATTENTIONFILE"'"

    while ((getline line < statefile) > 0) {
        split(line, p, "\t")
        prev[p[1]] = p[2]
    }
    close(statefile)

    while ((getline line < attentionfile) > 0) {
        attn[line] = 1
    }
    close(attentionfile)
}

function detectClaude(name,    b2) {
    if (index(name, "\xe2\x9c\xb3") == 1) return "idle"
    b2 = substr(name, 1, 2)
    if (b2 >= "\xe2\xa0" && b2 <= "\xe2\xa3") return "working"
    return ""
}

{
    tabId = $1; tabName = $2; termName = $3; focused = $4
    isWorking = 0; isIdle = 0

    # termName is always updated by Claude; tabName is fallback (user may override tab)
    state = detectClaude(termName)
    if (state == "") state = detectClaude(tabName)
    if (state == "") next

    if (state == "idle") isIdle = 1
    else isWorking = 1

    # Track state transitions — always flash on working→idle
    if (prev[tabId] == "working" && isIdle) attn[tabId] = 1
    if (isWorking) delete attn[tabId]

    # Clear attention if user is currently viewing this tab
    if (focused == "true") delete attn[tabId]

    cur[tabId] = isWorking ? "working" : "idle"

    dim = "\033[38;5;245m"
    yellow = "\033[33m"
    reset = "\033[0m"

    if (tabId in attn)
        # No reset — color bleeds into tab name for full-line highlight.
        # haunt adds reset at end of line.
        printf "%s\t%s\xe2\x9c\xb3 \n", tabId, yellow
    else if (isWorking)
        printf "%s\t%s\xe2\x97\x8c%s \n", tabId, dim, reset
}

END {
    for (id in cur) printf "%s\t%s\n", id, cur[id] > statefile
    close(statefile)
    for (id in attn) print id > attentionfile
    close(attentionfile)
}'
