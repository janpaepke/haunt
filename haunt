#!/usr/bin/env bash
#
# haunt — A tab switcher and session dashboard for Ghostty
#
# Displays an interactive, auto-refreshing list of all Ghostty tabs across
# all windows and macOS Spaces. Tabs are grouped by window (labeled with
# the common ancestor directory), with active tabs shown first.
#
# Selecting a tab switches to it, including cross-Space navigation.
# The list stays open for repeated switching — press Escape to quit.
#
# Requirements:
#   - macOS (uses Ghostty's AppleScript API)
#   - Ghostty (https://ghostty.org)
#   - fzf >= 0.48 (https://github.com/junegunn/fzf)
#
# Usage:
#   haunt              Launch the interactive tab dashboard
#   haunt --summon     Focus an already-running haunt instance
#   haunt --next       Jump to the next tab that needs attention
#   haunt --help       Show this help
#   haunt --version    Show version
#

set -euo pipefail

VERSION="0.3.1"
SELF="$(realpath "$0")"
REFRESH_INTERVAL=2
LOCKFILE="${TMPDIR:-/tmp}haunt.lock"
SCRIPTDIR="$(cd "$(dirname "$SELF")" && pwd)"
CONFIGFILE="${XDG_CONFIG_HOME:-$HOME/.config}/haunt/config"

# Default: enable all bundled hooks
HOOKS=""
if [[ -d "${SCRIPTDIR}/hooks" ]]; then
    for d in "${SCRIPTDIR}/hooks"/*/; do
        [[ -d "$d" ]] && HOOKS="${HOOKS} $(basename "$d")"
    done
fi

# User config can override (e.g. HOOKS="" to disable all, or a specific list)
if [[ -f "$CONFIGFILE" ]]; then
    # shellcheck source=/dev/null
    source "$CONFIGFILE"
fi

# ─── Help & version ──────────────────────────────────────────────────────────

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || "${1:-}" == "help" ]]; then
    sed -n '3,/^$/s/^# \{0,1\}//p' "$SELF"
    exit 0
fi

if [[ "${1:-}" == "--version" || "${1:-}" == "-v" || "${1:-}" == "version" ]]; then
    echo "haunt ${VERSION}"
    exit 0
fi

# ─── Hooks helper ─────────────────────────────────────────────────────────────

# Run a named hook across all enabled hooks. Extra args are passed through.
run_hooks() {
    local hook_name="$1"; shift
    for name in $HOOKS; do
        local script="${SCRIPTDIR}/hooks/${name}/${hook_name}"
        if [[ -x "$script" ]]; then
            "$script" "$@"
        fi
    done
}

# Collect decorator output from all enabled hooks into a single indicators file.
# Each decorator receives tab data on stdin (tsv: tabId \t tabName \t termName \t focused)
# and outputs lines of: tabId \t indicator (with ANSI color codes)
run_decorators() {
    local tab_data="$1"
    local outfile="$2"
    : > "$outfile"
    for name in $HOOKS; do
        local script="${SCRIPTDIR}/hooks/${name}/decorate"
        if [[ -x "$script" ]]; then
            echo "$tab_data" | "$script" >> "$outfile"
        fi
    done
}

# ─── Internal: fetch tab list (called by fzf reload) ─────────────────────────

if [[ "${1:-}" == "--list" ]]; then
    raw=$(osascript -e '
    tell application "Ghostty"
        set sep to ASCII character 31
        set output to ""
        set winList to every window
        repeat with w in winList
            set winId to id of w
            set tabList to every tab of w
            repeat with t in tabList
                set tabId to id of t
                set tabName to name of t
                set isSel to selected of t
                set term to focused terminal of t
                set wd to working directory of term
                set termName to name of term
                set output to output & winId & sep & tabId & sep & tabName & sep & isSel & sep & wd & sep & termName & linefeed
            end repeat
        end repeat
        return output
    end tell')

    # Build tab data for decorators: tabId \t tabName \t termName \t focused
    # "focused" = the tab the user is actually viewing right now.
    # Uses System Events AXMain attribute to find the keyboard-focused window
    # (Ghostty's own "front window" is unreliable — it reflects the last
    # AppleScript-activated window, not the user's actual focus).
    indicatorfile="${HAUNT_INDICATORFILE:-${TMPDIR:-/tmp}haunt-indicators}"
    # Find which tab the user is actually viewing via AXMain (keyboard-focused window).
    # If haunt's own tab is AXMain, the user is in the dashboard — skip focus detection.
    # AXMain is reliable even with floating windows (unlike Ghostty's "front window").
    haunt_tab_name=$(echo "$raw" | awk -F$'\x1f' -v self="$HAUNT_SELF" '$2 == self { print $3; exit }')
    focused_win_name=$(osascript -e '
    tell application "System Events"
        tell process "Ghostty"
            repeat with w in every window
                try
                    if value of attribute "AXMain" of w then return name of w
                end try
            end repeat
        end tell
    end tell' 2>/dev/null || echo "")
    # If the focused window is haunt itself, don't match anything
    if [[ "$focused_win_name" == "$haunt_tab_name" ]]; then
        focused_win_name=""
    fi
    # Match: a tab is "focused" if it is selected AND its name matches the
    # AXMain window. Name collisions across windows are possible but rare for
    # user-named tabs; Claude's default names (✳ Claude Code) are all idle anyway.
    tab_data=$(echo "$raw" | awk -F$'\x1f' -v fwn="$focused_win_name" 'NF >= 6 {
        focused = (fwn != "" && $4 == "true" && $3 == fwn) ? "true" : "false"
        print $2 "\t" $3 "\t" $6 "\t" focused
    }')
    run_decorators "$tab_data" "$indicatorfile"

    # Format tab data for fzf. Output fields (separated by \x1f):
    #   1: display text (visible)  2: winId (hidden)  3: tabId (hidden)
    # Indicators from hooks are prepended to the display text.
    echo "$raw" | LC_ALL=C awk -F$'\x1f' '
    BEGIN {
        ifile = ENVIRON["HAUNT_INDICATORFILE"]
        while ((getline line < ifile) > 0) {
            split(line, parts, "\t")
            indicators[parts[1]] = parts[2]
        }
        close(ifile)
    }

    NF >= 6 {
        winId = $1; tabId = $2; tabName = $3; selected = $4; wd = $5

        # Skip the tab running haunt itself
        if (tabId == ENVIRON["HAUNT_SELF"]) next

        # Strip Claude Code status prefix (✳ or braille spinner + space) from tab name
        b2 = substr(tabName, 1, 2)
        if ((substr(tabName, 1, 3) == "\xe2\x9c\xb3" || (b2 >= "\xe2\xa0" && b2 <= "\xe2\xa3")) && substr(tabName, 4, 1) == " ")
            tabName = substr(tabName, 5)

        totalTabs++
        tab[totalTabs, "winId"] = winId
        tab[totalTabs, "tabId"] = tabId
        tab[totalTabs, "tabName"] = tabName
        tab[totalTabs, "selected"] = selected
        tab[totalTabs, "wd"] = wd
        tab[totalTabs, "indicator"] = (tabId in indicators) ? indicators[tabId] : ""

        if (!(winId in winDirs)) {
            winDirs[winId] = wd
        } else {
            winDirs[winId] = winDirs[winId] "|" wd
        }
    }

    function commonAncestor(paths,    arr, n, i, refN, refParts, curParts, common, j, m, ref) {
        n = split(paths, arr, "|")
        if (n == 0) return ""
        if (n == 1) return arr[1]
        refN = split(arr[1], refParts, "/")
        common = refN
        for (i = 2; i <= n; i++) {
            m = split(arr[i], curParts, "/")
            if (m < common) common = m
            for (j = 1; j <= common; j++) {
                if (refParts[j] != curParts[j]) { common = j - 1; break }
            }
        }
        ref = ""
        for (j = 1; j <= common; j++) {
            if (j > 1) ref = ref "/"
            ref = ref refParts[j]
        }
        return ref
    }

    function shortPath(p,    home) {
        home = ENVIRON["HOME"]
        if (index(p, home) == 1) p = substr(p, length(home) + 1)
        sub(/^\//, "", p)
        return p
    }

    END {
        sep = sprintf("%c", 31)  # \x1f — fzf field delimiter
        dim = "\033[38;5;245m"
        reset = "\033[0m"

        # Group tabs by window, labeled with their common ancestor directory
        for (i = 1; i <= totalTabs; i++) {
            wId = tab[i, "winId"]
            if (!(wId in winSeen)) {
                winSeen[wId] = 1
                winCount++
                winList[winCount] = wId
                winLabel[wId] = shortPath(commonAncestor(winDirs[wId]))
                if (winLabel[wId] == "") winLabel[wId] = "~"
            }
        }

        # Sort windows alphabetically by label (insertion sort)
        for (i = 2; i <= winCount; i++) {
            key = winList[i]; keyLabel = winLabel[key]; j = i - 1
            while (j > 0 && (winLabel[winList[j]] > keyLabel || (winLabel[winList[j]] == keyLabel && winList[j] > key))) {
                winList[j + 1] = winList[j]; j--
            }
            winList[j + 1] = key
        }

        for (w = 1; w <= winCount; w++) {
            wId = winList[w]
            printf "%s\xf0\x9f\x96\xa5  %s%s%s_header_%s_header_\n", dim, winLabel[wId], reset, sep, sep
            for (i = 1; i <= totalTabs; i++) {
                if (tab[i, "winId"] != wId) continue
                ind = tab[i, "indicator"]
                if (ind != "")
                    # Hook indicator replaces the active marker; reset at end of line
                    printf "   %s%s%s%s%s%s%s\n", ind, tab[i, "tabName"], reset, sep, tab[i, "winId"], sep, tab[i, "tabId"]
                else if (tab[i, "selected"] == "true")
                    printf "   \xe2\x96\xb8 %s%s%s%s%s\n", tab[i, "tabName"], sep, tab[i, "winId"], sep, tab[i, "tabId"]
                else
                    printf "     %s%s%s%s%s\n", tab[i, "tabName"], sep, tab[i, "winId"], sep, tab[i, "tabId"]
            }
        }
    }' | {
        # Save header line positions for group jumping, pass output through
        n=0
        posfile="${HAUNT_INDICATORFILE:-${TMPDIR:-/tmp}haunt-indicators}.pos"
        : > "$posfile"
        while IFS= read -r line; do
            n=$((n + 1))
            echo "$line"
            case "$line" in *_header_*) echo "$n" >> "$posfile" ;; esac
        done
    }
    exit 0
fi

# ─── Internal: jump to next/prev group (called by fzf transform) ──────────────

if [[ "${1:-}" == "--jump-group" ]]; then
    direction="$2"
    current="$3"
    posfile="${HAUNT_INDICATORFILE:-${TMPDIR:-/tmp}haunt-indicators}.pos"

    [[ -f "$posfile" ]] || { echo "pos($current)"; exit 0; }

    if [[ "$direction" == "down" ]]; then
        # First header after current position, +1 to land on first tab
        while IFS= read -r h; do
            if [[ "$h" -gt "$current" ]]; then
                echo "pos($((h + 1)))"
                exit 0
            fi
        done < "$posfile"
    else
        # Find the header of the previous group.
        # First, find which header belongs to the current group (last header before current pos).
        # Then find the header before that one.
        prev_prev=""
        prev=""
        while IFS= read -r h; do
            [[ "$h" -ge "$current" ]] && break
            prev_prev="$prev"
            prev="$h"
        done < "$posfile"
        target="${prev_prev:-$prev}"
        if [[ -n "$target" ]]; then
            echo "pos($((target + 1)))"
            exit 0
        fi
    fi
    echo "pos($current)"
    exit 0
fi

# ─── Internal: focus a tab (called by fzf on selection) ──────────────────────

if [[ "${1:-}" == "--focus" ]]; then
    win_id="$2"
    tab_id="$3"

    # Notify hooks
    run_hooks "on-focus" "$tab_id"

    osascript -e "
    tell application \"Ghostty\"
        set w to (first window whose id is \"${win_id}\")
        set t to (first tab of w whose id is \"${tab_id}\")
        select tab t
        activate window w
    end tell"
    exit 0
fi

# ─── Summon: focus an already-running haunt instance ──────────────────────────

if [[ "${1:-}" == "--summon" || "${1:-}" == "summon" ]]; then
    if [[ -f "$LOCKFILE" ]]; then
        IFS=$'\t' read -r win_id tab_id < "$LOCKFILE" || true
        osascript -e "
        tell application \"Ghostty\"
            activate
            set w to (first window whose id is \"${win_id}\")
            set t to (first tab of w whose id is \"${tab_id}\")
            select tab t
            activate window w
        end tell" 2>/dev/null
    fi
    exit 0
fi

# ─── Next: jump to the next tab that needs attention ──────────────────────────

if [[ "${1:-}" == "--next" || "${1:-}" == "next" ]]; then
    # Collect attention tab IDs from all hooks
    tab_id=""
    for name in $HOOKS; do
        local_script="${SCRIPTDIR}/hooks/${name}/attention"
        if [[ -x "$local_script" ]]; then
            tab_id=$("$local_script" | head -1)
            [[ -n "$tab_id" ]] && break
        fi
    done

    if [[ -z "$tab_id" ]]; then
        echo "haunt: no tabs need attention" >&2
        exit 0
    fi

    # Look up the window ID for this tab
    win_id=$(osascript -e "
    tell application \"Ghostty\"
        repeat with w in every window
            repeat with t in every tab of w
                if id of t is \"${tab_id}\" then return id of w
            end repeat
        end repeat
        return \"\"
    end tell" 2>/dev/null)

    if [[ -z "$win_id" ]]; then
        echo "haunt: attention tab no longer exists" >&2
        exit 1
    fi

    # Clear attention for this tab via hooks, then focus it
    run_hooks "on-focus" "$tab_id"

    osascript -e "
    tell application \"Ghostty\"
        activate
        set w to (first window whose id is \"${win_id}\")
        set t to (first tab of w whose id is \"${tab_id}\")
        select tab t
        activate window w
    end tell" 2>/dev/null
    exit 0
fi

# ─── Dependency checks ───────────────────────────────────────────────────────

if [[ "$(uname)" != "Darwin" ]]; then
    echo "haunt: macOS is required (uses Ghostty's AppleScript API)" >&2
    exit 1
fi
if ! command -v fzf &>/dev/null; then
    echo "haunt: fzf is required but not found (brew install fzf)" >&2
    exit 1
fi

# ─── Launch ───────────────────────────────────────────────────────────────────

# Detect own tab so we can exclude it from the list
export HAUNT_SELF
read -r own_win_id own_tab_id <<< "$(osascript -e '
tell application "Ghostty"
    set w to front window
    return (id of w) & " " & (id of selected tab of w)
end tell' 2>/dev/null || echo "")"
HAUNT_SELF="$own_tab_id"

if [[ -z "$own_tab_id" ]]; then
    echo "haunt: Ghostty must be running" >&2
    exit 1
fi

export HAUNT_INDICATORFILE="${TMPDIR:-/tmp}haunt-indicators"

# Initialize hooks
run_hooks "on-start"

# Write lockfile so --summon can find us
printf '%s\t%s' "$own_win_id" "$own_tab_id" > "$LOCKFILE"

# Background process that triggers fzf reload every REFRESH_INTERVAL seconds
port=$((10000 + RANDOM % 50000))
(
    while true; do
        sleep "$REFRESH_INTERVAL"
        curl -s -XPOST "localhost:${port}" -d "reload($SELF --list)" >/dev/null 2>&1 || break
    done
) &
refresher_pid=$!
# shellcheck disable=SC2064
trap "run_hooks on-stop; rm -f '$LOCKFILE' '$HAUNT_INDICATORFILE'; kill $refresher_pid 2>/dev/null; wait $refresher_pid 2>/dev/null" EXIT

# Launch fzf — stays open for repeated selection, Escape to quit
"$SELF" --list | fzf \
    --ansi \
    --no-sort \
    --no-info \
    --layout=reverse \
    --prompt="haunt> " \
    --delimiter=$'\x1f' \
    --with-nth=1 \
    --listen="$port" \
    --bind "enter:execute-silent($SELF --focus {2} {3})+clear-query+reload($SELF --list)" \
    --bind "page-down:transform($SELF --jump-group down \$FZF_POS)" \
    --bind "page-up:transform($SELF --jump-group up \$FZF_POS)" \
|| true

kill "$refresher_pid" 2>/dev/null; wait "$refresher_pid" 2>/dev/null
